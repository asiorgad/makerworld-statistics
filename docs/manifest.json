{
  "name": "MakerStats",
  "version": "1.0.0",
  "home_assistant_domain": "",
  "funding_url": "",
  "new_install_prompt_erase": true,
  "_comment": "FIX: Flash individual components at correct offsets instead of merged binary at offset 0. This ensures bootloader, partitions, boot_app0, and app are placed at their proper memory locations, preventing boot crashes.",
  "builds": [
    {
      "chipFamily": "ESP32",
      "_comment": "ESP32 bootloader must be at 0x1000 (4096), not 0x0",
      "parts": [
        { "path": "firmware/makerstats.bootloader.bin", "offset": 4096 },
        { "path": "firmware/makerstats.partitions.bin", "offset": 32768 },
        { "path": "firmware/boot_app0.bin", "offset": 57344 },
        { "path": "firmware/makerstats.bin", "offset": 65536 }
      ]
    },
    {
      "chipFamily": "ESP32-C3",
      "parts": [
        { "path": "firmware/makerstats-c3.bootloader.bin", "offset": 0 },
        { "path": "firmware/makerstats-c3.partitions.bin", "offset": 32768 },
        { "path": "firmware/boot_app0.bin", "offset": 57344 },
        { "path": "firmware/makerstats-c3.bin", "offset": 65536 }
      ]
    },
    {
      "chipFamily": "ESP32-S3",
      "parts": [
        { "path": "firmware/makerstats-s3.bootloader.bin", "offset": 0 },
        { "path": "firmware/makerstats-s3.partitions.bin", "offset": 32768 },
        { "path": "firmware/boot_app0.bin", "offset": 57344 },
        { "path": "firmware/makerstats-s3.bin", "offset": 65536 }
      ]
    }
  ]
}
